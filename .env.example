# GCP project and deployment
PROJECT_ID=your-gcp-project
REGION=us-central1
JOB_NAME=tensorstore-dvid-export

# Source: GCS bucket containing DVID Arrow IPC shard files
# The bucket should contain per-scale directories: s0/, s1/, ..., each with .arrow + .csv pairs.
SOURCE_BUCKET=your-source-bucket
SOURCE_PREFIX=path/to/shard/export

# Destination: GCS bucket/path for neuroglancer precomputed output
DEST_BUCKET=your-dest-bucket
DEST_PATH=path/to/precomputed/output

# Neuroglancer spec JSON (same file used for DVID export-shards)
# This is the single source of truth for volume geometry and sharding params.
NG_SPEC_PATH=ng-specs.json

# Which scales to process (comma-separated). Workers scan s{N}/ for each scale.
SCALES=0,1

# Cloud Run job settings
PARALLELISM=200
TASK_COUNT=200
MAX_RETRIES=3
TASK_TIMEOUT=3600s
MEMORY=2Gi
CPU=2
